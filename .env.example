APP_NAME="Presensi Guru At-Taqwa"
# Development: local + true. Production di server: production + false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=presensi_guru
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==============================================================
# KONFIGURASI EMAIL (NOTIFIKASI IZIN/SAKIT)
# ==============================================================
# OPSI 1 — Gmail SMTP (DISARANKAN untuk XAMPP)
# Aktifkan "2-Step Verification" lalu buat "App Password" di Google.
# Ganti nilai di bawah dengan email dan App Password Google Anda.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=emailsekolah@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="emailsekolah@gmail.com"
MAIL_FROM_NAME="Sistem Presensi MA Attaqwa"

# OPSI 2 — Mailtrap (testing, tidak kirim email asli)
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=username_mailtrap
# MAIL_PASSWORD=password_mailtrap
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS="noreply@ma-attaqwa.sch.id"
# MAIL_FROM_NAME="Sistem Presensi MA Attaqwa"

# OPSI 3 — Log saja (lihat di storage/logs/laravel.log, tanpa kirim email)
# MAIL_MAILER=log
# MAIL_FROM_ADDRESS="noreply@ma-attaqwa.sch.id"
# MAIL_FROM_NAME="Sistem Presensi MA Attaqwa"
# ==============================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Wajib diisi di production (min. 32 karakter acak). Kosong = endpoint API ditolak.
FINGERPRINT_API_KEY=

# Password awal akun staff saat php artisan db:seed (wajib di production, min. 12 karakter)
SEED_SUPER_ADMIN_PASSWORD=
SEED_ADMIN_PASSWORD=
